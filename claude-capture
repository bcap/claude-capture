#!/bin/bash
#
# claude-capture - run `claude` with all its HTTP(S) traffic captured to a HAR file.
#
# All arguments passed to this script are passed to claude
#
# What it does:
#   1. Starts mitmweb in the background on a random ephemeral proxy port
#      (-p 0) and a pre-allocated ephemeral web-UI port bound to 127.0.0.1,
#      loading two local addons:
#        - streaming_har_ndjson.py: writes one HAR entry per line, live, as
#          flows complete (so the capture survives an unclean exit).
#        - port_writer.py: publishes the bound proxy port to a temp file so
#          this script can read it without parsing mitmweb's stdout.
#      The web-UI auth token is generated by this script and passed via
#      --set web_password=... so the wrapper can print the full URL with
#      the token embedded, instead of fishing mitmweb's own random token
#      out of its internals at runtime.
#      mitmweb's stdout/stderr are redirected to a temp log so they don't
#      corrupt claude's TUI; the log is dumped on early failure, otherwise
#      discarded on exit.
#   2. Waits for the proxy to bind, then runs `claude` with HTTPS_PROXY pointed
#      at it and NODE_EXTRA_CA_CERTS set to the mitmproxy CA so TLS validates.
#      Any args passed to this script are forwarded to `claude`.
#   3. After `claude` exits, gracefully stops mitmweb (SIGTERM, then SIGKILL
#      after 5s), assembles the NDJSON into a real HAR via scripts/ndjson_to_har.py,
#      and compresses it with the best available compressor
#      (zstd > xz > pigz > gzip; uncompressed if none are installed).
#
# Output:
#   .claude-traffic-<timestamp>.har[.zst|.xz|.gz] in the current working dir.
#
# Requirements:
#   mitmproxy (mitmweb), python3, and a trusted mitmproxy CA at
#   ~/.mitmproxy/mitmproxy-ca-cert.pem (created on first mitmweb run).
#
# Usage:
#   ./claude-capture [args passed through to claude]

set -euo pipefail

# If mitmweb isn't installed, warn loudly and fall through to a plain claude
# invocation so this script remains a drop-in replacement.
if ! command -v mitmweb >/dev/null; then

    cat >&2 <<'EOF'
==========================================================================
  WARNING: mitmproxy not installed (mitmweb not found on PATH).

  This wrapper uses mitmproxy to capture claude's traffic for post
  analysis.

  HTTP(S) traffic capture is DISABLED for this run.
  Claude will run normally, but no HAR file will be produced.

  To enable capture, install mitmproxy and re-run.
  There are several different ways to install it. Examples:
  - brew install mitmproxy
  - uv tool install mitmproxy
  - pipx install mitmproxy
  - apt install mitmproxy
  - pacman -S mitmproxy

  More at https://www.mitmproxy.org
==========================================================================

EOF

    exec claude "$@"
fi

APP_DIR="$(readlink -f $(dirname "$0"))"
HAR_FILE="$(date +"${CAPTURE_FILE_FORMAT:-.claude-traffic-%Y%m%d-%H%M%S.har}")"
ENTRIES_FILE="$HAR_FILE-entries.jsonl"
PORT_FILE="$(mktemp -t mitm-port.XXXXXX)"
MITM_LOG="$(mktemp -t mitm-log.XXXXXX)"

# Pre-allocate an ephemeral port for the web UI on 127.0.0.1. mitmweb's
# WebMaster.running() creates a tornado HTTPServer as a local variable and
# never exports its bound port back to options, so a `--web-port 0` would
# leave us with no way to discover what was bound. The socket-bind trick has
# a microsecond race window (port could be reused by another process between
# close and mitmweb's listen) but in practice this is the standard pattern.
WEB_PORT="$(python3 -c "import socket; s=socket.socket(); s.bind(('127.0.0.1',0)); print(s.getsockname()[1]); s.close()")"

# Generate the web-UI auth token ourselves so we can print the full URL with
# the token embedded. Passed via --set web_password=... below; mitmweb logs a
# "Using a plaintext password" warning on startup that gets discarded along
# with the rest of its redirected output.
WEB_TOKEN="$(python3 -c 'import secrets; print(secrets.token_hex(16))')"

# CAPTURE_COMPRESS: 1/true/yes/on (default) compresses the HAR; 0/false/no/off skips.
case "${CAPTURE_COMPRESS:-1}" in
    1|true|yes|on|TRUE|YES|ON|True|Yes|On)   CAPTURE_COMPRESS=1 ;;
    0|false|no|off|FALSE|NO|OFF|False|No|Off) CAPTURE_COMPRESS=0 ;;
    *) echo "claude-capture: invalid CAPTURE_COMPRESS='$CAPTURE_COMPRESS' (expected 1/0/true/false/yes/no/on/off)" >&2; exit 2 ;;
esac

graceful_stop() {
    local pid=${1:-}
    [[ -z "$pid" ]] && return 0
    kill -0 "$pid" 2>/dev/null || return 0
    kill -TERM "$pid" 2>/dev/null || true
    # Wait up to 5s for graceful shutdown.
    for _ in $(seq 1 50); do
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.1
    done
    if kill -0 "$pid" 2>/dev/null; then
        echo "[mitm] pid=$pid did not exit after SIGTERM, sending SIGKILL" >&2
        kill -KILL "$pid" 2>/dev/null || true
    fi
    wait "$pid" 2>/dev/null || true
}

cleanup() {
    graceful_stop "${MITM_PID:-}"
    MITM_PID=""
    rm -f "$PORT_FILE" "$MITM_LOG"
}
trap cleanup EXIT

# Dump mitmweb's captured log to stderr — used on early-failure paths so the
# user can see why mitmweb refused to bind.
dump_mitm_log() {
    if [[ -s "$MITM_LOG" ]]; then
        echo "[mitm] --- mitmweb log ---" >&2
        cat "$MITM_LOG" >&2
        echo "[mitm] --- end mitmweb log ---" >&2
    fi
}

# Extra flags for mitmweb from env (word-split; no shell-quote parsing).
read -r -a MITM_FLAGS_ARR <<< "${CAPTURE_MITM_FLAGS:-}"

# Start mitm proxy + web UI. stdout/stderr are redirected because claude's
# TUI takes over the terminal; any mitmweb output would corrupt the display.
mitmweb -q -p 0 \
    --web-host 127.0.0.1 --web-port "$WEB_PORT" --no-web-open-browser \
    --set web_password="$WEB_TOKEN" \
    -s "$APP_DIR/mitm/streaming_har_ndjson.py" --set har_ndjson="$ENTRIES_FILE" \
    -s "$APP_DIR/mitm/port_writer.py" --set port_file="$PORT_FILE" \
    "${MITM_FLAGS_ARR[@]}" >"$MITM_LOG" 2>&1 &
MITM_PID=$!

# Wait for the proxy to bind and publish its port (max ~10s).
for _ in $(seq 1 100); do
    [[ -s "$PORT_FILE" ]] && break
    kill -0 "$MITM_PID" 2>/dev/null || { echo "mitmweb died before binding" >&2; dump_mitm_log; exit 1; }
    sleep 0.1
done
[[ -s "$PORT_FILE" ]] || { echo "timed out waiting for mitmweb port" >&2; dump_mitm_log; exit 1; }
PORT=$(<"$PORT_FILE")
echo "[mitm] msg=\"proxy started\" proxy=127.0.0.1:$PORT pid=$MITM_PID webui=http://127.0.0.1:$WEB_PORT/?token=$WEB_TOKEN har_entries=$ENTRIES_FILE" >&2

# Run claude hooked to use mitm proxy
# Any extra args passed to the script are passed to claude
# Preserve claude's exit code so this script is a drop-in replacement.
PROXY_ADDRESS=http://127.0.0.1:$PORT
export HTTPS_PROXY=$PROXY_ADDRESS
export HTTP_PROXY=$PROXY_ADDRESS
export ALL_PROXY=$PROXY_ADDRESS
export https_proxy=$PROXY_ADDRESS
export http_proxy=$PROXY_ADDRESS
export all_proxy=$PROXY_ADDRESS

MITM_CA=~/.mitmproxy/mitmproxy-ca-cert.pem
export NODE_EXTRA_CA_CERTS="$MITM_CA"
export SSL_CERT_FILE="$MITM_CA"
export REQUESTS_CA_BUNDLE="$MITM_CA"
export CURL_CA_BUNDLE="$MITM_CA"
export GIT_SSL_CAINFO="$MITM_CA"
export AWS_CA_BUNDLE="$MITM_CA"

CLAUDE_RC=0
claude "$@" || CLAUDE_RC=$?

# Stop mitm proxy
graceful_stop "$MITM_PID"
MITM_PID=""
rm -f "$MITM_LOG"

# Compress the HAR with the best available compressor; fall back to plain.
# All listed tools delete the source on success.
compress_har() {
    if   command -v zstd  >/dev/null; then zstd  -q -9 --rm -- "$HAR_FILE" && echo "$HAR_FILE.zst"
    elif command -v xz    >/dev/null; then xz    -q -9      -- "$HAR_FILE" && echo "$HAR_FILE.xz"
    elif command -v pigz  >/dev/null; then pigz  -q -9      -- "$HAR_FILE" && echo "$HAR_FILE.gz"
    elif command -v gzip  >/dev/null; then gzip  -q -9      -- "$HAR_FILE" && echo "$HAR_FILE.gz"
    else echo "$HAR_FILE"
    fi
}

# Process entries and generate a final har file (skip if no entries captured)
if [[ -s "$ENTRIES_FILE" ]]; then
    ENTRY_COUNT=$(wc -l < "$ENTRIES_FILE")
    "$APP_DIR/scripts/ndjson_to_har.py" "$ENTRIES_FILE" "$HAR_FILE"
    rm -- "$ENTRIES_FILE"
    if [[ "$CAPTURE_COMPRESS" == 1 ]]; then
        OUT="$(compress_har)"
    else
        OUT="$HAR_FILE"
    fi
    echo "[mitm] msg=\"traffic captured\" output=$OUT num_entries=$ENTRY_COUNT" >&2
else
    rm -f -- "$ENTRIES_FILE"
fi

exit "$CLAUDE_RC"
